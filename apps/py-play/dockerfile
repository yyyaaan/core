# Dockerfile requires context at monorepo root! See line 33, use root Taskfile.yaml.

# --- Stage 1: Builder ---
FROM python:3.13-slim AS builder 

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY pyproject.toml uv.lock ./
COPY apps/py-play/pyproject.toml ./apps/py-play/
RUN uv sync --frozen --no-dev --no-install-project --package py-play

# --- Stage 2: Runtime ---
FROM python:3.13-slim AS runner

RUN apt update && apt install -y --no-install-recommends \
    mosquitto-clients \
    libsm6 \
    libxext6 \
    && rm -rf /var/lib/apt/lists/*

RUN playwright install-deps

WORKDIR /app

COPY --from=builder /app/.venv /app/.venv
COPY apps/py-play/src/play /app/play

ENV PATH="/app/.venv/bin:$PATH"

# Security: Run as non-root user
RUN groupadd -r appuser && useradd -r -g appuser appuser
USER appuser

# Expose the port
EXPOSE 7999

CMD ["fastapi", "run", "play/main.py", "--port", "7999", "--host", "0.0.0.0"]