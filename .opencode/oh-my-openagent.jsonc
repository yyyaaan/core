{
  "$schema": "http://json-schema.org/draft-07/schema#",
  
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  },

  "model_fallback": true,
  "default_run_agent": "sisyphus",

  "agents": {
    "sisyphus": {
      "model": "google/gemini-3-flash-preview", // Excellent choice for fast, cheap orchestration
      "temperature": 0.2,
      "prompt": "You are the orchestrator. Always read .opencode/context-map.md before delegating tasks.",
      "fallback_models": [
        { "model": "nvidia/meta/llama-3.1-70b-instruct" },
        { "model": "zen/auto" }
      ]
    },

    "prometheus": {
      "model": "deepseek/deepseek-reasoner",
      "temperature": 0.6,
      "prompt": "You are the planner. Outline step-by-step changes for the execution agent based on the specs folder.",
      "fallback_models": [
        { "model": "zen/deepseek-reasoner" }
      ]
    },

    "hephaestus": {
      "model": "deepseek/deepseek-chat",
      "temperature": 0.1,
      // Updated to Option B (Flat structure)
      "skills": [
        "./.opencode/skills/backend-logic/SKILL.md", 
        "./.opencode/skills/infra-helm/SKILL.md"
      ],
      "fallback_models": [
        { "model": "nvidia/meta/llama-3.1-405b-instruct" }
      ]
    },

    "librarian": {
      "model": "google/gemini-3.1-flash-lite",
      "temperature": 0.0,
      "fallback_models": [
        { "model": "zen/gemini-flash" }
      ]
    }
  }
}